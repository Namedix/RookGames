# BoardGameGeek XML API token (required since 2025-07-02).
# Register your application at https://boardgamegeek.com/applications
# (non-commercial license is free) and paste the bearer token here.
BGG_API_TOKEN=

# BoardGameGeek XML API base. Override only if you front it with a mirror.
BGG_BASE_URL=https://boardgamegeek.com/xmlapi2

# Upstash Redis (optional, auto-provisioned by the Upstash Marketplace
# integration on Vercel). Without these the backend uses the Vercel
# CDN cache only.
KV_REST_API_URL=
KV_REST_API_TOKEN=
